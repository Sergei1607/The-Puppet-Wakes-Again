[autoload]

PlayerBlackboard="*uid://davt04sr54xjn"
GameController="*uid://ulb7wdt3amta"
Settings="*uid://noe6e0rdestu"
UIManager="*uid://ddkvn02lntfe8"
AudioManager="*uid://b4engg7ohatat"

[display]

